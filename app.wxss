page {
  height: 100vh;
  width: 100%;
  overflow: hidden;
  overflow-x: hidden;
  background: #F3EDE3;
  color: #2E2A26;
  font-family: -apple-system, PingFang SC, Hiragino Sans GB, Microsoft YaHei, sans-serif;
}

@keyframes slideIn {
  from {
    opacity: 0;
    transform: translateY(10px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

view,
text,
button {
  box-sizing: border-box;
}

button {
  padding: 0;
  margin: 0;
  border: 0;
  background: transparent;
  line-height: inherit;
  color: inherit;
  font: inherit;
}

button::after {
  border: 0;
}

.button-hover {
  background: inherit !important;
  color: inherit !important;
  opacity: 1 !important;
}

.page {
  width: 100%;
  height: 100vh;
  overflow-x: hidden;
  overflow-y: auto;
  padding-top: 0;
  padding-bottom: calc(56px + 16px);
  background: #F3EDE3;
  animation: slideIn 0.3s ease;
}

.custom-nav {
  display: none;
}

.nav-inner {
  height: 50px;
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 18px;
  font-weight: 700;
  color: #2E2A26;
}

.nav-back {
  position: absolute;
  left: 0;
  top: 0;
  width: 50px;
  height: 50px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.section-title {
  width: 100%;
  box-sizing: border-box;
  padding: 16px 16px 8px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  color: #2E2A26;
}

.section-title-main {
  display: flex;
  align-items: center;
  flex-shrink: 0;
  font-size: 15px;
  font-weight: 700;
}

.section-title-main::before {
  content: "";
  width: 3px;
  height: 16px;
  margin-right: 8px;
  border-radius: 2px;
  background: #A96532;
}

.section-more {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  margin-left: auto;
  min-width: 56px;
  color: #8A7D70;
  font-size: 13px;
}

.card-row {
  width: 100%;
  padding: 0 16px;
  box-sizing: border-box;
  font-size: 0;
  white-space: nowrap;
}

.service-card {
  display: inline-block;
  vertical-align: top;
  width: 105px;
  padding: 16px 12px;
  border-radius: 12px;
  border: 1px solid #E6D9C8;
  background: linear-gradient(180deg, #FFFDF9, #F8F1E8);
  text-align: center;
  margin-right: 10px;
  font-size: 13px;
}

.service-card .title,
.benefit-item .title {
  margin-top: 7px;
  font-size: 13px;
  font-weight: 600;
  color: #2E2A26;
}

.service-card .sub,
.benefit-item .sub {
  margin-top: 4px;
  font-size: 11px;
  color: #8A7D70;
}

.content-card {
  display: inline-block;
  vertical-align: top;
  width: 160px;
  overflow: hidden;
  border-radius: 12px;
  border: 1px solid #E6D9C8;
  background: #FFFDF9;
  margin-right: 10px;
  font-size: 14px;
}

.content-cover {
  height: 140px;
  display: flex;
  align-items: center;
  justify-content: center;
  background:
    repeating-linear-gradient(25deg, transparent 0 34px, rgba(93, 58, 26, 0.035) 34px 35px),
    linear-gradient(135deg, #E7DAC7, #D4C2AA);
}

.content-body {
  padding: 10px 12px 12px;
}

.content-tag {
  color: #9A5C2E;
  font-size: 10px;
  font-weight: 700;
  letter-spacing: 1px;
}

.content-title {
  margin-top: 5px;
  color: #2E2A26;
  font-size: 14px;
  font-weight: 600;
  line-height: 1.4;
  white-space: normal;
}

.content-meta {
  margin-top: 5px;
  color: #8A7D70;
  font-size: 12px;
}

.story-card {
  position: relative;
  margin: 12px;
  padding: 20px 16px 20px 20px;
  overflow: hidden;
  border-radius: 16px;
  border: 1px solid #E6D9C8;
  background: linear-gradient(180deg, #FFFDF9, #F8F1E8);
}

.story-card::before {
  content: "";
  position: absolute;
  left: 0;
  top: 18px;
  bottom: 18px;
  width: 4px;
  border-radius: 4px;
  background: linear-gradient(180deg, #A96532, #5D3A1A);
}

.story-quote {
  position: relative;
  padding-left: 18px;
  color: #2E2A26;
  font-size: 14px;
  font-weight: 600;
  line-height: 1.8;
}

.story-quote::before {
  content: "\"";
  position: absolute;
  left: 0;
  top: -13px;
  color: rgba(169, 101, 50, 0.28);
  font-family: Georgia, serif;
  font-size: 36px;
  line-height: 1;
}

.story-author {
  margin-top: 8px;
  padding-left: 18px;
  color: #8A7D70;
  font-size: 12px;
}

.benefit-grid {
  display: flex;
  flex-wrap: wrap;
  padding: 0 8px;
  margin: 8px 0;
}

.benefit-item {
  width: calc(50% - 8px);
  margin: 0 4px 8px;
  padding: 14px 12px;
  border-radius: 10px;
  border: 1px solid #E6D9C8;
  background: linear-gradient(180deg, #FFFDF9, #F8F1E8);
  text-align: center;
}

.service-card brand-icon,
.benefit-item brand-icon,
.tier-item brand-icon {
  display: block;
  width: 100%;
  margin-left: auto;
  margin-right: auto;
}

.benefit-row {
  display: flex;
  padding: 0 8px;
}

.benefit-row .benefit-item {
  flex: 1;
  width: auto;
  margin: 0 4px 8px;
}

.list-item {
  width: calc(100% - 24px);
  display: flex;
  align-items: center;
  margin: 0 12px 1px;
  padding: 14px 16px;
  border-bottom: 1px solid #E8DDCF;
  background: #FFFDF9;
}

.list-item.first {
  border-radius: 12px 12px 0 0;
}

.list-item.last {
  margin-bottom: 12px;
  border-radius: 0 0 12px 12px;
}

.list-item.single {
  margin-bottom: 12px;
  border-radius: 12px;
}

.list-icon {
  margin-right: 12px;
}

.list-info {
  flex: 1;
}

.list-title {
  color: #2E2A26;
  font-size: 15px;
  font-weight: 500;
}

.list-sub {
  margin-top: 4px;
  color: #8A7D70;
  font-size: 12px;
}

.list-value {
  margin-right: 8px;
  color: #8B552E;
  font-size: 13px;
  font-weight: 600;
}

.divider {
  height: 8px;
  background: #F3EDE3;
}

.banner-tip {
  margin: 12px;
  padding: 12px 14px;
  display: flex;
  align-items: center;
  border-radius: 12px;
  border: 1px solid #E7D8C4;
  background: linear-gradient(135deg, #F8F1E8, #EFE2D2);
  color: #6B4B2C;
  font-size: 13px;
  line-height: 1.5;
}

.qr-card {
  margin: 16px 12px 0;
  padding: 32px 20px;
  border-radius: 16px;
  border: 1px solid #E6D9C8;
  background: #FFFDF9;
  text-align: center;
}

.qr-step {
  margin-bottom: 12px;
  color: #8B552E;
  font-size: 12px;
  font-weight: 600;
  letter-spacing: 1px;
}

.qr-placeholder {
  width: 160px;
  height: 160px;
  margin: 0 auto 16px;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 2px dashed #D7BEA3;
  border-radius: 8px;
  background: #F3EDE3;
}

.qr-title {
  margin: 0;
  color: #2E2A26;
  font-size: 17px;
  font-weight: 700;
}

.qr-card .desc {
  margin-top: 10px;
  color: #5F5750;
  font-size: 13px;
  line-height: 1.7;
}

.tips {
  margin-top: 14px;
  padding: 10px;
  border-radius: 8px;
  border: 1px solid #E9DAC7;
  background: #F8F1E8;
  color: #5F5750;
  font-size: 12px;
  line-height: 1.6;
}

.btn-primary {
  width: calc(100% - 24px);
  margin: 12px 12px 0;
  padding: 14px;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 24px;
  background: #8B552E;
  color: #FFFFFF;
  font-size: 16px;
  font-weight: 700;
}

.btn-primary text {
  margin-left: 8px;
}
