.brand-story {
  margin: 12px;
  overflow: hidden;
  border-radius: 16px;
  border: 1px solid #E6D9C8;
  background: #FFFDF9;
}

.brand-cover {
  height: 160px;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background:
    repeating-linear-gradient(26deg, transparent 0 36px, rgba(245,226,201,0.035) 36px 37px),
    linear-gradient(160deg, #5D3A1A, #3E2614, #2A170B);
}

.brand-word {
  color: #E6CFB4;
  font-size: 28px;
  font-weight: 800;
  letter-spacing: 6px;
}

.brand-tagline {
  margin-top: 10px;
  color: rgba(250,241,228,0.45);
  font-size: 11px;
  letter-spacing: 2px;
}

.brand-body {
  padding: 18px 16px 20px;
}

.brand-title {
  color: #2E2A26;
  font-size: 18px;
  font-weight: 700;
}

.brand-text {
  margin-top: 10px;
  color: #5F5750;
  font-size: 13px;
  line-height: 1.8;
}

.inspiration-row {
  display: flex;
  justify-content: space-between;
  height: 244px;
  overflow: hidden;
  padding: 0 16px;
  white-space: normal;
  align-items: stretch;
}

.inspiration-row .content-card {
  margin-right: 0;
  height: 244px;
  display: flex;
  flex-direction: column;
}

.inspiration-row .content-cover {
  height: 118px;
  flex: 0 0 118px;
}

.inspiration-row .content-body {
  flex: 1;
  padding: 9px 11px 10px;
}

.inspiration-row .content-title {
  line-height: 1.45;
}

.inspiration-row .content-meta {
  line-height: 1.4;
}

.benefit-row .benefit-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.cover-two {
  background:
    repeating-linear-gradient(-18deg, transparent 0 32px, rgba(93, 58, 26, 0.04) 32px 33px),
    linear-gradient(135deg, #DED0BC, #CDB79E);
}
